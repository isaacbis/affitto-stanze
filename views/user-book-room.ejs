<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>Prenota stanza</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="page">
    <div class="container modern">
      <div class="topbar glass">
        <div>
          <h1>Prenota stanza</h1>
          <p class="subtitle">Scegli stanza, data e fascia oraria disponibile</p>
        </div>
        <div>
          <a class="btn-link" href="/user/dashboard">Dashboard</a>
          <a class="btn-link danger-link" href="/logout">Logout</a>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert success"><%= success %></div>
      <% } %>

      <div class="card glass">
        <form method="POST" action="/user/book-room" id="bookingForm">
          <div class="form-grid">
            <div>
              <label>Stanza</label>
              <select name="room_id" id="roomSelect" required>
                <option value="">Seleziona stanza</option>
                <% rooms.forEach(r => { %>
                  <option value="<%= r.id %>"><%= r.name %></option>
                <% }) %>
              </select>
            </div>

            <div>
              <label>Data</label>
              <input type="date" name="booking_date" id="bookingDate" required>
            </div>
          </div>

          <div class="legend">
            <span class="legend-item"><span class="dot free"></span> Libero</span>
            <span class="legend-item"><span class="dot busy"></span> Occupato</span>
            <span class="legend-item"><span class="dot selected"></span> Selezionato</span>
          </div>

          <details class="slots-dropdown" open>
            <summary>Apri / chiudi fasce orarie</summary>
            <div id="slotsContainer" class="slots-grid"></div>
          </details>

          <div class="selected-box">
            <p><strong>Inizio selezionato:</strong> <span id="selectedStartText">-</span></p>
            <p><strong>Fine selezionata:</strong> <span id="selectedEndText">-</span></p>
          </div>

          <input type="hidden" name="start_hour" id="startHourInput" required>
          <input type="hidden" name="end_hour" id="endHourInput" required>

          <button type="submit" class="primary-btn">Conferma prenotazione</button>
        </form>
      </div>
    </div>
  </div>

<script>
  const roomSelect = document.getElementById('roomSelect');
  const bookingDate = document.getElementById('bookingDate');
  const slotsContainer = document.getElementById('slotsContainer');
  const startHourInput = document.getElementById('startHourInput');
  const endHourInput = document.getElementById('endHourInput');
  const selectedStartText = document.getElementById('selectedStartText');
  const selectedEndText = document.getElementById('selectedEndText');

  let occupiedSlots = [];
  let selectedStart = null;
  let selectedEnd = null;

  function formatHour(value) {
    const numeric = Number(value);
    const hours = Math.floor(numeric);
    const minutes = numeric % 1 === 0.5 ? 30 : 0;
    return String(hours).padStart(2, '0') + ':' + String(minutes).padStart(2, '0');
  }

  function normalizeSlot(value) {
    return Number(Number(value).toFixed(1));
  }

  function resetSelection() {
    selectedStart = null;
    selectedEnd = null;
    startHourInput.value = '';
    endHourInput.value = '';
    selectedStartText.textContent = '-';
    selectedEndText.textContent = '-';
  }

  function buildSlots() {
    slotsContainer.innerHTML = '';

    for (let h = 8; h < 20; h += 0.5) {
      const slotValue = normalizeSlot(h);

      const slot = document.createElement('button');
      slot.type = 'button';
      slot.className = 'slot-btn';
      slot.dataset.hour = slotValue;
      slot.textContent = formatHour(slotValue);

      if (occupiedSlots.includes(slotValue)) {
        slot.classList.add('busy');
        slot.disabled = true;
      } else {
        slot.classList.add('free');
        slot.addEventListener('click', () => handleSlotClick(slotValue));
      }

      slotsContainer.appendChild(slot);
    }

    refreshSelectedUI();
  }

  function refreshSelectedUI() {
    document.querySelectorAll('.slot-btn').forEach(btn => {
      btn.classList.remove('selected');
      const hour = Number(btn.dataset.hour);

      if (
        selectedStart !== null &&
        selectedEnd !== null &&
        hour >= selectedStart &&
        hour < selectedEnd
      ) {
        btn.classList.add('selected');
      }
    });

    selectedStartText.textContent = selectedStart !== null ? formatHour(selectedStart) : '-';
    selectedEndText.textContent = selectedEnd !== null ? formatHour(selectedEnd) : '-';
  }

  function handleSlotClick(hour) {
    hour = normalizeSlot(hour);

    if (selectedStart === null) {
      selectedStart = hour;
      selectedEnd = normalizeSlot(hour + 0.5);
    } else if (selectedStart !== null && selectedEnd !== null) {
      if (hour < selectedStart) {
        selectedStart = hour;
      } else {
        selectedEnd = normalizeSlot(hour + 0.5);
      }

      for (let h = selectedStart; h < selectedEnd; h += 0.5) {
        const current = normalizeSlot(h);
        if (occupiedSlots.includes(current)) {
          alert('Hai incluso una fascia occupata. Seleziona solo orari liberi consecutivi.');
          resetSelection();
          refreshSelectedUI();
          return;
        }
      }
    }

    startHourInput.value = selectedStart;
    endHourInput.value = selectedEnd;
    refreshSelectedUI();
  }

  async function loadAvailability() {
    const roomId = roomSelect.value;
    const date = bookingDate.value;

    resetSelection();
    slotsContainer.innerHTML = '';

    if (!roomId || !date) return;

    try {
      const response = await fetch(`/user/availability?room_id=${roomId}&booking_date=${date}`);
      const data = await response.json();

      occupiedSlots = (data.occupiedSlots || []).map(v => normalizeSlot(v));
      buildSlots();
    } catch (err) {
      console.error(err);
      slotsContainer.innerHTML = '<p>Errore nel caricamento disponibilità</p>';
    }
  }

  roomSelect.addEventListener('change', loadAvailability);
  bookingDate.addEventListener('change', loadAvailability);

  const today = new Date();
  const yyyy = today.getFullYear();
  const mm = String(today.getMonth() + 1).padStart(2, '0');
  const dd = String(today.getDate()).padStart(2, '0');
  const todayStr = `${yyyy}-${mm}-${dd}`;

  bookingDate.min = todayStr;
  bookingDate.value = todayStr;
  loadAvailability();
</script>
</body>
</html>