<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Utente</title>
<link rel="stylesheet" href="/style.css?v=<%= assetVersion %>">
</head>
<body>
<%
  function formatTime(value) {
    const num = Number(value);
    const hours = Math.floor(num);
    const minutes = num % 1 === 0.5 ? 30 : 0;
    return String(hours).padStart(2, '0') + ':' + String(minutes).padStart(2, '0');
  }
%>
  <div class="page">
    <div class="container modern">
      <div class="topbar glass">
        <div>
          <h1>Dashboard Utente</h1>
          <p class="subtitle">Consulta le tue prenotazioni, prenota rapidamente una stanza e gestisci la tua password</p>
        </div>
        <div class="topbar-actions">
          <span class="user-chip">👤 <strong><%= user.username %></strong></span>
          <a class="btn-link danger-link" href="/logout">Logout</a>
        </div>
      </div>

      <div class="nav modern-nav">
        <a href="/user/dashboard" class="active">Dashboard</a>
        <a href="/user/book-room">Prenota stanza</a>
        <a href="/user/my-bookings">Le mie prenotazioni</a>
      </div>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert success"><%= success %></div>
      <% } %>

      <div class="dashboard-grid">
        <div class="card hero-card">
          <div>
            <h2>Prenotazione rapida</h2>
            <p>Seleziona una stanza e guarda subito gli slot verdi e rossi in tempo reale.</p>
          </div>
          <a href="/user/book-room" class="hero-action">Apri prenotazione</a>
        </div>

        <div class="card glass password-card password-dropdown-card">
  <details class="password-dropdown">
    <summary>
      <div class="password-dropdown-head">
        <div>
          <h2>Cambia password</h2>
          <p class="muted-text">Apri il pannello per aggiornare la tua password</p>
        </div>
        <div class="password-dropdown-side">
          <span class="badge badge-blue">Profilo</span>
          <span class="password-dropdown-icon">⌄</span>
        </div>
      </div>
    </summary>

    <div class="password-dropdown-body">
      <form method="POST" action="/user/change-password" class="stack-form">
        <label>Password attuale</label>
        <input type="password" name="current_password" required>

        <label>Nuova password</label>
        <input type="password" name="new_password" required>

        <label>Conferma nuova password</label>
        <input type="password" name="confirm_password" required>

        <button type="submit" class="primary-btn">Aggiorna password</button>
      </form>
    </div>
  </details>
</div>
      </div>

      <div class="card glass">
        <div class="section-head">
          <h2>Ultime prenotazioni</h2>
          <span class="badge badge-violet"><%= bookings.length %> visibili</span>
        </div>

        <div class="table-wrap">
          <table class="user-latest-table compact-table">
            <tr>
              <th>Stanza</th>
              <th>Data</th>
              <th>Da</th>
              <th>A</th>
              <th>Ore</th>
            </tr>
            <% bookings.forEach(b => { %>
              <tr>
                <td><strong><%= b.room_name %></strong></td>
                <td><%= b.booking_date %></td>
                <td><%= formatTime(b.start_hour) %></td>
                <td><%= formatTime(b.end_hour) %></td>
                <td><span class="hours-chip"><%= b.total_hours %>h</span></td>
              </tr>
            <% }) %>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>