<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Utente</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="page">
    <div class="container modern">
      <div class="topbar glass">
        <div>
          <h1>Dashboard Utente</h1>
          <p class="subtitle">Consulta le tue prenotazioni e prenota rapidamente una stanza</p>
        </div>
        <div class="topbar-actions">
          <span class="user-chip">👤 <strong><%= user.username %></strong></span>
          <a class="btn-link danger-link" href="/logout">Logout</a>
        </div>
      </div>

      <div class="nav modern-nav">
        <a href="/user/dashboard" class="active">Dashboard</a>
        <a href="/user/book-room">Prenota stanza</a>
        <a href="/user/my-bookings">Le mie prenotazioni</a>
      </div>

      <div class="card hero-card">
        <div>
          <h2>Prenotazione rapida</h2>
          <p>Seleziona una stanza e guarda subito gli slot verdi e rossi in tempo reale.</p>
        </div>
        <a href="/user/book-room" class="hero-action">Apri prenotazione</a>
      </div>

      <div class="card glass">
        <div class="section-head">
          <h2>Ultime prenotazioni</h2>
          <span class="badge badge-violet"><%= bookings.length %> visibili</span>
        </div>

        <div class="table-wrap">
          <table>
            <tr>
              <th>Stanza</th>
              <th>Data</th>
              <th>Da</th>
              <th>A</th>
              <th>Ore</th>
            </tr>
            <% bookings.forEach(b => { %>
              <tr>
                <td><strong><%= b.room_name %></strong></td>
                <td><%= b.booking_date %></td>
                <td><%= String(b.start_hour).padStart(2, '0') %>:00</td>
                <td><%= String(b.end_hour).padStart(2, '0') %>:00</td>
                <td><span class="hours-chip"><%= b.total_hours %>h</span></td>
              </tr>
            <% }) %>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>