<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prenotazioni Admin</title>
<link rel="stylesheet" href="/style.css?v=<%= assetVersion %>">
</head>
<body>
<%
  function formatTime(value) {
    const num = Number(value);
    const hours = Math.floor(num);
    const minutes = num % 1 === 0.5 ? 30 : 0;
    return String(hours).padStart(2, '0') + ':' + String(minutes).padStart(2, '0');
  }
%>
  <div class="page">
    <div class="container modern">
      <div class="topbar glass">
        <div>
          <h1>Prenotazioni Admin</h1>
          <p class="subtitle">Inserisci prenotazioni per gli utenti e gestisci tutte quelle presenti</p>
        </div>
        <div class="topbar-actions">
          <a class="btn-link" href="/admin/dashboard">Dashboard</a>
          <a class="btn-link danger-link" href="/logout">Logout</a>
        </div>
      </div>

      <div class="nav modern-nav">
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/users">Utenti</a>
        <a href="/admin/rooms">Stanze</a>
        <a href="/admin/bookings" class="active">Prenotazioni</a>
        <a href="/admin/reports">Report</a>
      </div>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert success"><%= success %></div>
      <% } %>

      <div class="admin-bookings-layout">
        <div class="card glass">
          <div class="section-head">
            <h2>Nuova prenotazione admin</h2>
            <span class="badge badge-blue">Privata</span>
          </div>

          <form method="POST" action="/admin/bookings/create" id="adminBookingForm">
            <div class="form-grid">
              <div>
                <label>Utente</label>
                <select name="user_id" id="adminUserSelect" required>
                  <option value="">Seleziona utente</option>
                  <% users.forEach(u => { %>
                    <option value="<%= u.id %>"><%= u.username %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label>Stanza</label>
                <select name="room_id" id="adminRoomSelect" required>
                  <option value="">Seleziona stanza</option>
                  <% rooms.forEach(r => { %>
                    <option value="<%= r.id %>"><%= r.name %></option>
                  <% }) %>
                </select>
              </div>

              <div>
                <label>Data</label>
                <input type="date" name="booking_date" id="adminBookingDate" required>
              </div>
            </div>

            <div class="admin-note-field">
              <label>Nota privata admin</label>
              <textarea
                name="admin_note"
                rows="3"
                placeholder="Scrivi una nota visibile solo lato admin"
              ></textarea>
            </div>

            <div class="legend">
              <span class="legend-item"><span class="dot free"></span> Libero</span>
              <span class="legend-item"><span class="dot busy"></span> Occupato</span>
              <span class="legend-item"><span class="dot selected"></span> Selezionato</span>
            </div>

            <details class="slots-dropdown" open>
              <summary>Apri / chiudi fasce orarie</summary>
              <div id="adminSlotsContainer" class="slots-grid"></div>
            </details>

            <div class="selected-box">
              <p><strong>Inizio selezionato:</strong> <span id="adminSelectedStartText">-</span></p>
              <p><strong>Fine selezionata:</strong> <span id="adminSelectedEndText">-</span></p>
            </div>

            <input type="hidden" name="start_hour" id="adminStartHourInput" required>
            <input type="hidden" name="end_hour" id="adminEndHourInput" required>

            <button type="submit" class="primary-btn">Conferma prenotazione admin</button>
          </form>
        </div>

        <div class="card glass">
          <div class="section-head">
            <h2>Elenco prenotazioni</h2>
            <span class="badge badge-blue"><%= bookings.length %> totali</span>
          </div>

          <div class="table-wrap">
            <table class="compact-table bookings-table">
              <tr>
                <th>Utente</th>
                <th>Stanza</th>
                <th>Data</th>
                <th>Da</th>
                <th>A</th>
                <th>Ore</th>
                <th class="admin-note-col">ℹ️</th>
                <th>X</th>
              </tr>

              <% bookings.forEach(b => { %>
                <tr>
                  <td class="booking-user-cell"><strong><%= b.username %></strong></td>
<td class="booking-room-cell"><%= b.room_name %></td>
                  <td><%= b.booking_date %></td>
                  <td><%= formatTime(b.start_hour) %></td>
                  <td><%= formatTime(b.end_hour) %></td>
                  <td><span class="hours-chip"><%= b.total_hours %>h</span></td>
                  <td>
                    <% if (b.admin_note) { %>
                      <details class="admin-note-toggle">
                        <summary>ℹ️</summary>
                        <div class="admin-note-box"><%= b.admin_note %></div>
                      </details>
                    <% } else { %>
                      <span class="muted-small">-</span>
                    <% } %>
                  </td>
                  <td>
                    <form method="POST" action="/admin/bookings/delete/<%= b.id %>" data-confirm="Vuoi davvero eliminare questa prenotazione?">
  <button type="submit" class="delete-btn icon-action-btn">X</button>
</form>
                  </td>
                </tr>
              <% }) %>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

<script src="/js/confirm-forms.js?v=<%= assetVersion %>"></script>
<script src="/js/admin-bookings.js?v=<%= assetVersion %>"></script>
</body>
</html>